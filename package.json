{
  "name": "bun-serve-compress",
  "version": "0.1.0",
  "description": "Transparent HTTP response compression for Bun.serve() — gzip, brotli, zstd",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "bun test",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "bun-types": ">=1.3.3"
  },
  "devDependencies": {
    "bun-types": "^1.3.9",
    "typescript": "^5.7"
  },
  "keywords": [
    "bun",
    "compression",
    "gzip",
    "brotli",
    "zstd",
    "http",
    "server",
    "serve"
  ],
  "license": "MIT",
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rhuanbarreto/bun-serve-compress"
  }
}
