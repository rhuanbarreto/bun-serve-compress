{
  "name": "bun-serve-compress",
  "version": "0.1.0",
  "description": "Transparent HTTP response compression for Bun.serve() — gzip, brotli, zstd",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "test": "bun test",
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build ./src/index.ts --outdir ./dist --target bun --minify",
    "build:types": "tsc --emitDeclarationOnly",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "bun-types": "^1.3.9",
    "typescript": "^5.7"
  },
  "keywords": [
    "bun",
    "compression",
    "gzip",
    "brotli",
    "zstd",
    "http",
    "server",
    "serve",
    "bun-serve",
    "content-encoding",
    "accept-encoding"
  ],
  "license": "MIT",
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rhuanbarreto/bun-serve-compress"
  },
  "homepage": "https://github.com/rhuanbarreto/bun-serve-compress#readme",
  "bugs": {
    "url": "https://github.com/rhuanbarreto/bun-serve-compress/issues"
  },
  "engines": {
    "bun": ">=1.3.3"
  }
}
